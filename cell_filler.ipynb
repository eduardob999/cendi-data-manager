# Install necessary packages
!pip install pandas prompt_toolkit

import pandas as pd
from prompt_toolkit import prompt
from prompt_toolkit.completion import WordCompleter
from google.colab import files

# Upload the main CSV file
uploaded = files.upload()

for file_name in uploaded.keys():
    main_file_path = file_name
    break

main_df = pd.read_csv(main_file_path)

# Ask for the date
date = input("Enter the date for attendance (e.g., 2023-10-01): ")

# Create a new column for attendance if it doesn't exist
attendance_column = f'Attendance_{date
}'
if attendance_column not in main_df.columns:
    main_df[attendance_column
] = 0  # Initialize with 0

# Create a completer for CÉDULA values
cedula_completer = WordCompleter([str(cedula) for cedula in main_df['CÉDULA'
  ]
], ignore_case=True)

# Enter attendance data for each personnel
while True:
    cedula = prompt("Enter CÉDULA (or type 'done' to finish): ", completer=cedula_completer)
    if cedula.lower() == 'done':
        break
    if cedula.isdigit():
        cedula = int(cedula)
        if cedula in main_df['CÉDULA'
].values:
            main_df.loc[main_df['CÉDULA'
  ] == cedula, attendance_column
] += 1
        else:
            print(f"CÉDULA {cedula} not found in the main CSV.")
    else:
        print("Invalid CÉDULA. Please enter a numeric value.")

# Save the updated DataFrame back to CSV
main_df.to_csv(main_file_path, index=False)

print(f"Attendance for {date} updated successfully.")